# ═══════════════════════════════════════════
#   12 TRIBES — BACKEND CONFIGURATION
#   Copy to .env and fill in your values
# ═══════════════════════════════════════════

# ─── SERVER ───
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:5173

# ─── DATABASE (PostgreSQL) ───
DATABASE_URL=postgresql://tribes_user:your_password@localhost:5432/twelve_tribes
DB_HOST=localhost
DB_PORT=5432
DB_NAME=twelve_tribes
DB_USER=tribes_user
DB_PASSWORD=your_password
DB_SSL=false

# ─── AUTHENTICATION ───
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING
JWT_EXPIRY=24h
JWT_REFRESH_EXPIRY=7d
BCRYPT_ROUNDS=12

# ─── ALPACA BROKERAGE ───
# Paper trading (sandbox) — get keys at https://app.alpaca.markets/paper/dashboard/overview
ALPACA_PAPER_API_KEY=
ALPACA_PAPER_API_SECRET=
ALPACA_PAPER_BASE_URL=https://paper-api.alpaca.markets
ALPACA_PAPER_DATA_URL=https://data.alpaca.markets

# Live trading — get keys at https://app.alpaca.markets/
ALPACA_LIVE_API_KEY=
ALPACA_LIVE_API_SECRET=
ALPACA_LIVE_BASE_URL=https://api.alpaca.markets
ALPACA_LIVE_DATA_URL=https://data.alpaca.markets

# OAuth (for user-linked accounts)
ALPACA_OAUTH_CLIENT_ID=
ALPACA_OAUTH_CLIENT_SECRET=
ALPACA_OAUTH_REDIRECT_URI=http://localhost:4000/api/broker/alpaca/callback

# ─── MARKET DATA ───
# Polygon.io (real-time WebSocket + REST)
POLYGON_API_KEY=

# Alternative: Alpaca data stream (included with Alpaca account)
USE_ALPACA_DATA=true

# ─── RISK MANAGEMENT ───
MAX_POSITION_SIZE_PCT=10
MAX_DAILY_LOSS_PCT=5
MAX_PORTFOLIO_DRAWDOWN_PCT=15
KILL_SWITCH_DRAWDOWN_PCT=25
MAX_ORDERS_PER_MINUTE=10
REQUIRE_CONFIRMATION_ABOVE=10000

# ─── RATE LIMITING ───
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ─── LOGGING ───
LOG_LEVEL=info
LOG_FILE=logs/server.log
